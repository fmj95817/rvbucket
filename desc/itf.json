{
    "itfs_desc": {
        "fch_req": {
            "type": "vld-rdy",
            "payloads": [
                { "name": "pc", "width": 32 }
            ]
        },
        "fch_rsp": {
            "type": "vld-rdy",
            "payloads": [
                { "name": "ir", "width": 32 },
                { "name": "ok", "width": 1 },
                { "name": "expt", "width": 1 },
                { "name": "cause", "width": 32 },
                { "name": "priv", "width": 2 },
                { "name": "tval", "width": 32 }
            ]
        },

        "ex_req": {
            "type": "vld-rdy",
            "include": ["spec/core/isa.h"],
            "include_rtl": ["spec/core/isa.svh"],
            "payloads": [
                { "name": "inst", "ext_type": "rv32g_inst_t", "raw": "raw", "width": 32 },
                { "name": "pc", "width": 32 },
                { "name": "pred_taken", "width": 1 },
                { "name": "pred_pc", "width": 32 },
                { "name": "is_boot_code", "width": 1 }
            ]
        },
        "ex_rsp": {
            "type": "vld-rdy",
            "payloads": [
                { "name": "pc", "width": 32 },
                { "name": "taken", "width": 1 },
                { "name": "pred_true", "width": 1 },
                { "name": "target_pc", "width":32  }
            ]
        },

        "bpu_pred_req": {
            "type": "none",
            "payloads": [
                { "name": "vld", "width": 1 },
                { "name": "pc", "width": 32 },
                { "name": "ir", "width": 32 }
            ]
        },
        "bpu_pred_rsp": {
            "type": "none",
            "payloads": [
                { "name": "vld", "width": 1 },
                { "name": "is_ctrl", "width": 1 },
                { "name": "pred_taken", "width": 1 },
                { "name": "pred_pc", "width": 32 },
                { "name": "cond_bht_hit", "width": 1 },
                { "name": "jalr_ras_hit", "width": 1 },
                { "name": "jalr_btb_hit", "width": 1 },
                { "name": "jalr_btb_miss", "width": 1 }
            ]
        },
        "bpu_update": {
            "type": "none",
            "payloads": [
                { "name": "vld", "width": 1 },
                { "name": "pc", "width": 32 },
                { "name": "ir", "width": 32 },
                { "name": "taken", "width": 1 },
                { "name": "target_pc", "width": 32 },
                { "name": "pred_taken", "width": 1 },
                { "name": "pred_pc", "width": 32 },
                { "name": "pred_true", "width": 1 },
                { "name": "is_boot_code", "width": 1 },
                { "name": "pred_cond_bht_hit", "width": 1 },
                { "name": "pred_jalr_ras_hit", "width": 1 },
                { "name": "pred_jalr_btb_hit", "width": 1 },
                { "name": "pred_jalr_btb_miss", "width": 1 }
            ]
        },

        "exu_csr_read_req": {
            "type": "none",
            "payloads": [
                { "name": "addr", "width": 12 },
                { "name": "priv", "width": 2 }
            ]
        },

        "csr_exu_read_rsp": {
            "type": "none",
            "payloads": [
                { "name": "val", "width": 32 },
                { "name": "ok", "width": 1 }
            ]
        },

        "exu_csr_write_req": {
            "type": "vld",
            "payloads": [
                { "name": "addr", "width": 12 },
                { "name": "val", "width": 32 },
                { "name": "priv", "width": 2 }
            ]
        },

        "csr_exu_write_rsp": {
            "type": "vld",
            "payloads": [
                { "name": "ok", "width": 1 }
            ]
        },

        "trap_csr_write_req": {
            "type": "vld",
            "payloads": [
                { "name": "addr", "width": 12 },
                { "name": "val", "width": 32 }
            ]
        },

        "csr_trap_write_rsp": {
            "type": "vld",
            "payloads": [
                { "name": "ok", "width": 1 }
            ]
        },

        "exu_state": {
            "type": "none",
            "payloads": [
                { "name": "priv", "width": 2 },
                { "name": "pc", "width": 32 },
                { "name": "irq_epc", "width": 32 },
                { "name": "irq_defer", "width": 1 },
                { "name": "wfi", "width": 1 },
                { "name": "wfi_resume_pc", "width": 32 }
            ]
        },

        "trap_exu_ctrl": {
            "type": "vld",
            "payloads": [
                { "name": "priv", "width": 2 },
                { "name": "irq_epc", "width": 32 },
                { "name": "wfi", "width": 1 }
            ]
        },

        "csr_mmu_state": {
            "type": "none",
            "payloads": [
                { "name": "satp", "width": 32 },
                { "name": "mstatus", "width": 32 }
            ]
        },

        "csr_lsu_state": {
            "type": "none",
            "payloads": [
                { "name": "satp", "width": 32 }
            ]
        },

        "csr_trap_state": {
            "type": "none",
            "payloads": [
                { "name": "mstatus", "width": 32 },
                { "name": "mip", "width": 32 },
                { "name": "mie", "width": 32 },
                { "name": "mtvec", "width": 32 },
                { "name": "mepc", "width": 32 },
                { "name": "medeleg", "width": 32 },
                { "name": "mideleg", "width": 32 },
                { "name": "sstatus", "width": 32 },
                { "name": "sip", "width": 32 },
                { "name": "sie", "width": 32 },
                { "name": "stvec", "width": 32 },
                { "name": "sepc", "width": 32 }
            ]
        },

        "fl_req": {
            "type": "vld",
            "payloads": []
        },

        "tlb_flush": {
            "type": "vld",
            "payloads": []
        },

        "l1_flush": {
            "type": "vld",
            "payloads": []
        },

        "l1_flush_ack": {
            "type": "vld",
            "payloads": []
        },

        "ldst_req": {
            "type": "vld-rdy",
            "enums": {
                "size": {
                    "b1": 0,
                    "b2": 1,
                    "b4": 2
                }
            },
            "payloads": [
                { "name": "addr", "width": 32 },
                { "name": "st", "width": 1 },
                { "name": "size", "type": "size" },
                { "name": "data", "width": 32 },
                { "name": "strobe", "width": 4 }
            ]
        },
        "ldst_rsp": {
            "type": "vld-rdy",
            "payloads": [
                { "name": "data", "width": 32 },
                { "name": "ok", "width": 1 }
            ]
        },

        "bti_req": {
            "type": "vld-rdy",
            "enums": {
                "cmd": {
                    "read": 0,
                    "write": 1
                },
                "size": {
                    "b1": 0,
                    "b2": 1,
                    "b4": 2
                }
            },
            "payloads": [
                { "name": "trans_id", "width": 16 },
                { "name": "cmd", "type": "cmd" },
                { "name": "addr", "width": 32 },
                { "name": "size", "type": "size" },
                { "name": "data", "width": 32 },
                { "name": "strobe", "width": 4 }
            ]
        },
        "bti_rsp": {
            "type": "vld-rdy",
            "payloads": [
                { "name": "trans_id", "width": 16 },
                { "name": "data", "width": 32 },
                { "name": "ok", "width": 1 }
            ]
        },

        "apb_req": {
            "type": "none",
            "trace_when": "__itf_trace_ctrl_changed()",
            "payloads": [
                { "name": "paddr", "width": 32 },
                { "name": "pwrite", "width": 1 },
                { "name": "pwdata", "width": 32 },
                { "name": "pstrb", "width": 4 }
            ],
            "ctrl": [
                { "name": "psel", "width": 1 },
                { "name": "penable", "width": 1 }
            ]
        },
        "apb_rsp": {
            "type": "none",
            "trace_when": "__itf_trace_ctrl_changed()",
            "payloads": [
                { "name": "prdata", "width": 32 },
                { "name": "pslverr", "width": 1 }
            ],
            "ctrl": [
                { "name": "pready", "width": 1 }
            ]
        },

        "axi4_ar": {
            "type": "vld-rdy",
            "enums": {
                "burst": {
                    "fixed": 0,
                    "incr": 1,
                    "wrap": 2
                },
                "size": {
                    "b1": 0,
                    "b2": 1,
                    "b4": 2,
                    "b8": 3,
                    "b16": 4,
                    "b32": 5,
                    "b64": 6,
                    "b128": 7
                }
            },
            "payloads": [
                { "name": "id", "width": 8 },
                { "name": "addr", "width": 32 },
                { "name": "len", "width": 8 },
                { "name": "size", "type": "size" },
                { "name": "burst", "type": "burst" },
                { "name": "lock", "width": 1 },
                { "name": "cache", "width": 4 },
                { "name": "prot", "width": 3 },
                { "name": "qos", "width": 4 },
                { "name": "user", "width": 32 }
            ]
        },
        "axi4_r": {
            "type": "vld-rdy",
            "enums": {
                "resp": {
                    "okay": 0,
                    "exokay": 1,
                    "slverr": 2,
                    "decerr": 3
                }
            },
            "payloads": [
                { "name": "id", "width": 8 },
                { "name": "data", "width": 32 },
                { "name": "resp", "type": "resp" },
                { "name": "last", "width": 1 }
            ]
        },
        "axi4_aw": {
            "type": "vld-rdy",
            "enums": {
                "burst": {
                    "fixed": 0,
                    "incr": 1,
                    "wrap": 2
                },
                "size": {
                    "b1": 0,
                    "b2": 1,
                    "b4": 2,
                    "b8": 3,
                    "b16": 4,
                    "b32": 5,
                    "b64": 6,
                    "b128": 7
                }
            },
            "payloads": [
                { "name": "id", "width": 8 },
                { "name": "addr", "width": 32 },
                { "name": "len", "width": 8 },
                { "name": "size", "type": "size" },
                { "name": "burst", "type": "burst" },
                { "name": "lock", "width": 1 },
                { "name": "cache", "width": 4 },
                { "name": "prot", "width": 3 },
                { "name": "qos", "width": 4 },
                { "name": "user", "width": 32 }
            ]
        },
        "axi4_w": {
            "type": "vld-rdy",
             "payloads": [
                { "name": "data", "width": 32 },
                { "name": "strb", "width": 4 },
                { "name": "last", "width": 1 }
             ]
        },
        "axi4_b": {
             "type": "vld-rdy",
             "enums": {
                 "resp": {
                     "okay": 0,
                     "exokay": 1,
                     "slverr": 2,
                     "decerr": 3
                 }
             },
             "payloads": [
                { "name": "id", "width": 8 },
                { "name": "resp", "type": "resp" }
             ]
        },

        "core_timer": {
            "type": "none",
            "payloads": [
                { "name": "time", "width": 64, "rtl_alias": "mtime" }
            ]
        },

        "core_m_irq": {
            "type": "none",
            "payloads": [
                { "name": "mtimer", "width": 1 },
                { "name": "msw", "width": 1 }
            ]
        },

        "core_s_irq": {
            "type": "none",
            "payloads": [
                { "name": "ssw", "width": 1 }
            ]
        },

        "core_swi_pend": {
            "type": "none",
            "payloads": [
                { "name": "msip", "width": 1 }
            ]
        },

        "ext_irq": {
            "type": "none",
            "payloads": [
                { "name": "irq", "width": 1 }
            ]
        },

        "gpio": {
            "type": "none",
            "model_only": true,
            "payloads": [
                { "name": "val", "width": 32 }
            ]
        },

        "hart_expt": {
            "type": "vld",
            "enums": {
                "type": {
                    "exception": 0,
                    "mret": 1,
                    "sret": 2
                },
                "cause": {
                    "inst_addr_misaligned": 0,
                    "inst_access_fault": 1,
                    "illegal_inst": 2,
                    "breakpoint": 3,
                    "load_addr_misaligned": 4,
                    "load_access_fault": 5,
                    "store_amo_addr_misaligned": 6,
                    "store_amo_access_fault": 7,
                    "ecall": 8,
                    "inst_page_fault": 12,
                    "load_page_fault": 13,
                    "store_amo_page_fault": 15,
                    "double_trap": 16,
                    "sw_check": 18,
                    "hw_error": 19
                }
            },
            "payloads": [
                { "name": "type", "type": "type", "rtl_alias": "expt_type" },
                { "name": "cause", "type": "cause" },
                { "name": "priv", "width": 2 },
                { "name": "pc", "width": 32 },
                { "name": "tval", "width": 32 }
            ]
        },

        "trap_send": {
            "type": "vld",
            "payloads": [
                { "name": "target_pc", "width": 32 }
            ]
        },

        "uart": {
            "type": "vld",
            "model_only": true,
            "payloads": [
                { "name": "data", "width": 32 }
            ]
        }
    }
}
