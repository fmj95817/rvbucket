`ifndef SPEC_IO_SDSPI_SVH
`define SPEC_IO_SDSPI_SVH

`define SDSPI_REG_VERSION       6'h00
`define SDSPI_REG_CAP           6'h04
`define SDSPI_REG_CTRL          6'h08
`define SDSPI_REG_CLOCK         6'h0c
`define SDSPI_REG_STATUS        6'h10
`define SDSPI_REG_CMD_ARG       6'h14
`define SDSPI_REG_CMD_CTRL      6'h18
`define SDSPI_REG_CMD_STATUS    6'h1c
`define SDSPI_REG_RESP0         6'h20
`define SDSPI_REG_RESP1         6'h24
`define SDSPI_REG_DMA_ADDR      6'h28
`define SDSPI_REG_BLOCK_SIZE    6'h2c
`define SDSPI_REG_BLOCK_COUNT   6'h30
`define SDSPI_REG_DATA_STATUS   6'h34
`define SDSPI_REG_IRQ_STATUS    6'h38
`define SDSPI_REG_IRQ_ENABLE    6'h3c

`define SDSPI_VERSION           32'h00010000
`define SDSPI_CAP               32'h00800003

`define SDSPI_CTRL_ENABLE       32'h00000001
`define SDSPI_CTRL_SW_RESET     32'h00000002

`define SDSPI_STATUS_CARD_PRESENT 32'h00000001
`define SDSPI_STATUS_CARD_RO       32'h00000002
`define SDSPI_STATUS_BUSY          32'h00000004
`define SDSPI_STATUS_CARD_IDLE     32'h00000008

`define SDSPI_CMD_CTRL_OPCODE_MASK 32'h0000003f
`define SDSPI_CMD_CTRL_RSP_MASK    32'h00000700
`define SDSPI_CMD_CTRL_DATA        32'h00001000
`define SDSPI_CMD_CTRL_WRITE       32'h00002000
`define SDSPI_CMD_CTRL_START       32'h80000000

`define SDSPI_CMD_STATUS_DONE      32'h00000001
`define SDSPI_CMD_STATUS_ERROR     32'h00000002
`define SDSPI_CMD_STATUS_TIMEOUT   32'h00000004
`define SDSPI_CMD_STATUS_ILLEGAL   32'h00000008
`define SDSPI_CMD_STATUS_ADDRESS   32'h00000010
`define SDSPI_CMD_STATUS_PARAMETER 32'h00000020

`define SDSPI_DATA_STATUS_DONE      32'h00000001
`define SDSPI_DATA_STATUS_ERROR     32'h00000002
`define SDSPI_DATA_STATUS_AXI_ERROR 32'h00000004
`define SDSPI_DATA_STATUS_IO_ERROR  32'h00000008

`define SDSPI_IRQ_CMD_DONE       32'h00000001
`define SDSPI_IRQ_DATA_DONE      32'h00000002
`define SDSPI_IRQ_ERROR          32'h00000004
`define SDSPI_IRQ_CARD_CHANGE    32'h00000008
`define SDSPI_IRQ_MASK           32'h0000000f

`define SDSPI_SECTOR_SIZE        32'd512
`define SDSPI_MAX_DATA_SIZE      32'd65536

`endif
